# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Requires a Google App Password (NOT your regular Gmail password).
# Steps:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" → "Other (Custom name)".
#   4. Paste the 16-character password below (no spaces).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Recipients ───────────────────────────────────────────────────────────────
# Comma-separated list of email addresses to receive the weekly digest.
RECIPIENT_EMAIL=you@gmail.com,colleague@gmail.com

# ── EDGAR ────────────────────────────────────────────────────────────────────
# SEC EDGAR requires a valid contact email in the User-Agent header.
# Use the same address as GMAIL_USER or any valid email you own.
EDGAR_CONTACT_EMAIL=you@gmail.com

# ── Optional ─────────────────────────────────────────────────────────────────
# Override the default SQLite database file location
# DB_PATH=/path/to/ipo_filings.db
