# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Requires a Google App Password (NOT your regular Gmail password).
# Steps:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" → "Other (Custom name)".
#   4. Paste the 16-character password below (no spaces).
GMAIL_USER=alexanderasbury@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Recipient ────────────────────────────────────────────────────────────────
RECIPIENT_EMAIL=alexanderasbury@gmail.com

# ── Optional ─────────────────────────────────────────────────────────────────
# Override the default SQLite database file location
# DB_PATH=/path/to/ipo_filings.db
